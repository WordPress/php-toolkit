{
	"name": "wp-php-toolkit/bytestream",
	"description": "ByteStream component for WordPress.",
	"type": "library",
	"authors": [
		{
			"name": "Adam Zielinski",
			"email": "adam@adamziel.com"
		},
		{
			"name": "WordPress Team",
			"email": "wordpress@wordpress.org"
		}
	],
	"require": {
		"php": ">=7.2"
	},
	"autoload": {
		"classmap": [
			"./"
		],
		"exclude-from-classmap": [
			"/Tests/"
		]
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5"
	},
	"archive": {
		"exclude": [
			"**/.github/",
			"**/Tests/",
			"**/bin/"
		]
	}
}
