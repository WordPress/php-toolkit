{
	"name": "wp-php-toolkit/git",
	"description": "Git component for WordPress.",
	"type": "library",
	"authors": [
		{
			"name": "Adam Zielinski",
			"email": "adam@adamziel.com"
		},
		{
			"name": "WordPress Team",
			"email": "wordpress@wordpress.org"
		}
	],
	"require": {
		"php": ">=7.2",
		"wp-php-toolkit/bytestream": "dev-trunk",
		"wp-php-toolkit/filesystem": "dev-trunk",
		"wp-php-toolkit/http-client": "*"
	},
	"autoload": {
		"psr-4": {
			"WordPress\\Git\\": ""
		},
		"files": [
			"functions.php"
		],
		"exclude-from-classmap": [
			"/Tests/"
		]
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5"
	},
	"archive": {
		"exclude": [
			"/Tests/",
			"/bin/"
		]
	}
}
