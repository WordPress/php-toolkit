{
    "name": "wp-php-toolkit/git",
    "description": "Git component for WordPress.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "require": {
        "php": ">=7.2",
        "wp-php-toolkit/bytestream": "^0.7",
        "wp-php-toolkit/filesystem": "^0.7",
        "wp-php-toolkit/http-client": "^0.7"
    },
    "autoload": {
        "psr-4": {
            "WordPress\\Git\\": ""
        },
        "files": [
            "functions.php"
        ],
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    }
}
