{
	"name": "wp-php-toolkit/http-server",
	"description": "HttpServer component for WordPress.",
	"type": "library",
	"authors": [
		{
			"name": "Adam Zielinski",
			"email": "adam@adamziel.com"
		},
		{
			"name": "WordPress Team",
			"email": "wordpress@wordpress.org"
		}
	],
	"require": {
		"php": ">=7.2",
		"wp-php-toolkit/bytestream": "dev-trunk",
		"wp-php-toolkit/data-liberation": "dev-trunk",
		"wp-php-toolkit/http-client": "dev-trunk"
	},
	"autoload": {
		"psr-4": {
			"WordPress\\HttpServer\\": ""
		},
		"exclude-from-classmap": [
			"/Tests/"
		]
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"archive": {
		"exclude": [
			"**/.github/",
			"**/Tests/",
			"**/bin/"
		]
	}
}
