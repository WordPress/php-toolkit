{
    "name": "wp-php-toolkit/data-liberation",
    "description": "Data Liberation component for WordPress.",
    "type": "library",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "require": {
        "php": ">=7.2",
        "wp-php-toolkit/bytestream": "^0.2",
        "wp-php-toolkit/filesystem": "^0.2",
        "wp-php-toolkit/http-client": "^0.2",
        "wp-php-toolkit/xml": "^0.2"
    },
    "autoload": {
        "classmap": [
            "./",
            "vendor-patched/"
        ],
        "files": [
            "URL/functions.php"
        ],
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "archive": {
        "exclude": [
            "**/.github/",
            "**/Tests/",
            "**/bin/"
        ]
    }
}
