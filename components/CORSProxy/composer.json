{
    "name": "wp-php-toolkit/corsproxy",
    "description": "CORSProxy component for WordPress.",
    "version": "0.0.1",
    "type": "library",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "require": {
        "php": ">=7.2"
    },
    "autoload": {
        "psr-4": {
            "WordPress\\CORSProxy\\": ""
        },
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "archive": {
        "exclude": [
            "**/.github/",
            "**/Tests/",
            "**/bin/"
        ]
    }
}
