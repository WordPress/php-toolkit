{
    "name": "wp-php-toolkit/zip",
    "description": "Zip component for WordPress.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "php-toolkit"
    ],
    "homepage": "https://wordpress.github.io/php-toolkit/reference/zip.html",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "support": {
        "issues": "https://github.com/WordPress/php-toolkit/issues",
        "source": "https://github.com/WordPress/php-toolkit",
        "docs": "https://wordpress.github.io/php-toolkit/reference/zip.html"
    },
    "require": {
        "php": ">=7.2",
        "wp-php-toolkit/bytestream": "^0.8.1",
        "wp-php-toolkit/filesystem": "^0.8.1",
        "wp-php-toolkit/http-client": "^0.8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "classmap": [
            "./"
        ],
        "files": [
            "functions.php"
        ],
        "exclude-from-classmap": [
            "/Tests/"
        ]
    }
}
