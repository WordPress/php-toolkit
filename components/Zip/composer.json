{
    "name": "wp-php-toolkit/zip",
    "description": "Zip component for WordPress.",
    "version": "0.0.1",
    "type": "library",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "require": {
        "php": ">=7.2",
        "wp-php-toolkit/bytestream": "^0.0.8",
        "wp-php-toolkit/filesystem": "^0.0.8",
        "wp-php-toolkit/http-client": "^0.0.8"
    },
    "autoload": {
        "psr-4": {
            "WordPress\\Zip\\": ""
        },
        "files": [
            "src/functions.php"
        ],
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "archive": {
        "exclude": [
            "**/.github/",
            "**/Tests/",
            "**/bin/"
        ]
    }
}
