{
	"name": "wp-php-toolkit/zip",
	"description": "Zip component for WordPress.",
	"type": "library",
	"authors": [
		{
			"name": "Adam Zielinski",
			"email": "adam@adamziel.com"
		},
		{
			"name": "WordPress Team",
			"email": "wordpress@wordpress.org"
		}
	],
	"require": {
		"php": ">=7.2",
		"wp-php-toolkit/bytestream": "*",
		"wp-php-toolkit/filesystem": "*",
		"wp-php-toolkit/http-client": "*"
	},
	"autoload": {
		"psr-4": {
			"WordPress\\Zip\\": ""
		},
		"files": [
			"src/functions.php"
		],
		"exclude-from-classmap": [
			"/Tests/"
		]
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5"
	}
}
