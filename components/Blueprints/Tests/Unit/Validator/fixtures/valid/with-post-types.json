					{
						"content": "This is a sample book."
					}
				]
			],
			"template_lock": "all"
		},
		"author": "/path/to/author-post-type.php"
	},
	"content": [
		{
			"type": "posts",
			"source": [
				{
					"post_title": "Sample Book",
					"post_content": "This is a sample book.",
					"post_type": "book"
				}
			]
		}
	]
}
