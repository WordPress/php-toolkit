{
    "name": "wp-php-toolkit/blueprints",
    "description": "Blueprints component for WordPress.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "php-toolkit"
    ],
    "homepage": "https://wordpress.github.io/php-toolkit/reference/blueprints.html",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
    "support": {
        "issues": "https://github.com/WordPress/php-toolkit/issues",
        "source": "https://github.com/WordPress/php-toolkit",
        "docs": "https://wordpress.github.io/php-toolkit/reference/blueprints.html"
    },
    "require": {
        "php": ">=7.2",
        "wp-php-toolkit/bytestream": "^0.8.1",
        "wp-php-toolkit/filesystem": "^0.8.1",
        "wp-php-toolkit/http-client": "^0.8.1",
        "wp-php-toolkit/xml": "^0.8.1",
        "wp-php-toolkit/zip": "^0.8.1"
    },
    "autoload": {
        "classmap": [
            "./"
        ],
        "exclude-from-classmap": [
            "/Tests/",
            "/bin/",
            "/Steps/scripts/",
            "/vendor-patched/symfony/event-dispatcher/DependencyInjection/",
            "/vendor-patched/symfony/event-dispatcher/ContainerAwareEventDispatcher.php"
        ]
    }
}
