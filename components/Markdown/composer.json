{
	"name": "wp-php-toolkit/markdown",
	"description": "Markdown component for WordPress.",
	"type": "library",
    "authors": [
        {
            "name": "Adam Zielinski",
            "email": "adam@adamziel.com"
        },
        {
            "name": "WordPress Team",
            "email": "wordpress@wordpress.org"
        }
    ],
	"require": {
		"php": ">=7.2",
		"wp-php-toolkit/data-liberation": "dev-trunk",
		"wp-php-toolkit/filesystem": "dev-trunk"
	},
	"autoload": {
		"classmap": [
			"vendor-patched"
		],
		"psr-4": {
			"WordPress\\Markdown\\": ""
		},
        "exclude-from-classmap": [
            "/Tests/"
        ]
	},
	"archive": {
		"exclude": [
			"**/.github/",
			"**/Tests/",
			"**/bin/"
		]
	}
}
